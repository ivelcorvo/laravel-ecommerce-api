# ═════════════════════════════════════════════════════════════
# DOCKER COMPOSE
# ═════════════════════════════════════════════════════════════

# Slug do projeto — usado como prefixo dos containers,
# imagem Docker e nome do projeto Compose.
APP_SLUG=ecommerce-api

# Versão do PHP a buildar (8.3 mínimo para Laravel 13)
PHP_VERSION=8.4

# UID/GID do usuário do host (evita problemas de permissão).
# Descubra com `id -u` e `id -g` no Linux/Mac.
UID=1000
GID=1000

# Portas expostas no host
NGINX_PORT=8080
DB_PORT=5432
REDIS_PORT=6379
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025


# ═════════════════════════════════════════════════════════════
# APLICAÇÃO LARAVEL
# ═════════════════════════════════════════════════════════════

APP_NAME="Laravel Ecommerce API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

# ─── Manutenção ────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file


# ═════════════════════════════════════════════════════════════
# LOGS
# ═════════════════════════════════════════════════════════════

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug


# ═════════════════════════════════════════════════════════════
# BANCO DE DADOS — PostgreSQL
# (DB_HOST = nome do serviço no docker-compose)
# ═════════════════════════════════════════════════════════════

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ecommerce
DB_USERNAME=ecommerce
DB_PASSWORD=secret


# ═════════════════════════════════════════════════════════════
# CACHE / SESSÃO / FILAS — Redis
# ═════════════════════════════════════════════════════════════

# Para uma API stateless pura, SESSION_DRIVER pode ser `array`.
# Mantenha `redis` se for usar rotas web/Livewire também.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Em produção (HTTPS): true. Em dev local (HTTP): false.
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=redis
CACHE_PREFIX=

QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1


# ═════════════════════════════════════════════════════════════
# FILESYSTEM
# ═════════════════════════════════════════════════════════════

FILESYSTEM_DISK=local

# ═════════════════════════════════════════════════════════════
# API / SANCTUM
# (configurar quando instalar laravel/sanctum)
# ═════════════════════════════════════════════════════════════

# Domínios autorizados a usar autenticação via cookie (SPA).
# Para API token-based puro, ignorar.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# Frontend que consome a API (CORS)
FRONTEND_URL=http://localhost:3000


# ═════════════════════════════════════════════════════════════
# PRODUÇÃO — checklist obrigatório antes do deploy
# ═════════════════════════════════════════════════════════════
# [ ] APP_ENV=production
# [ ] APP_DEBUG=false
# [ ] APP_URL com HTTPS
# [ ] SESSION_SECURE_COOKIE=true
# [ ] LOG_LEVEL=warning (ou error)
# [ ] DB_PASSWORD e REDIS_PASSWORD com senhas fortes únicas
# [ ] Remover `ports` de postgres e redis no docker-compose.yml
# [ ] php artisan config:cache && route:cache && view:cache
# [ ] OPcache validate_timestamps=0 no php.ini
