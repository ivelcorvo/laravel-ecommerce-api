docker-compose.override.yml

# ─────────────────────────────────────────────────────────────
# Laravel — tudo dentro de src/ é gerado/instalado depois
# Comente as linhas abaixo se você for versionar a aplicação
# junto com o template (monorepo).
# ─────────────────────────────────────────────────────────────
src/vendor/
src/node_modules/
src/public/build/
src/public/hot/
src/public/storage/
src/storage/*.key
src/storage/pail/
src/storage/logs/*
!src/storage/logs/.gitkeep
src/storage/framework/cache/data/*
src/storage/framework/sessions/*
src/storage/framework/testing/*
src/storage/framework/views/*
src/bootstrap/cache/*.php
src/.phpunit.result.cache
src/.phpunit.cache/
src/auth.json
src/.idea
src/.vscode
src/Homestead.json
src/Homestead.yaml

# ─────────────────────────────────────────────────────────────
# Editores
# ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────
# Sistema operacional
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
